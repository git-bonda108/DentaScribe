{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DentaScribe SOAP Note",
  "type": "object",
  "required": [
    "metadata",
    "subjective",
    "objective",
    "assessment",
    "plan",
    "billing",
    "compliance",
    "grounding"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "encounter_id",
        "date_of_service",
        "provider",
        "patient",
        "visit_type"
      ],
      "properties": {
        "encounter_id": {
          "type": "string"
        },
        "date_of_service": {
          "type": "string",
          "format": "date"
        },
        "provider": {
          "type": "object",
          "required": [
            "name",
            "tsbde_license"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "tsbde_license": {
              "type": "string"
            },
            "npi": {
              "type": "string"
            }
          }
        },
        "patient": {
          "type": "object",
          "required": [
            "patient_id",
            "dob",
            "consent_on_file"
          ],
          "properties": {
            "patient_id": {
              "type": "string"
            },
            "dob": {
              "type": "string"
            },
            "consent_on_file": {
              "type": "boolean"
            },
            "medical_alerts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "medications": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allergies": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "visit_type": {
          "type": "string",
          "description": "Both short ('recall') and long ('recall_exam') aliases are accepted. The visit-type templates in data/visit_type_templates.json normalize these.",
          "enum": [
            "emergency",
            "emergency_limited",
            "new_patient_exam",
            "new_patient_comprehensive",
            "recall",
            "recall_exam",
            "periodic_recall",
            "restorative",
            "restorative_direct",
            "restorative_indirect",
            "endo",
            "endodontic",
            "perio",
            "periodontal_hygiene",
            "hygiene",
            "extraction",
            "oral_surgery",
            "ortho_consult",
            "post_op_followup",
            "other"
          ]
        },
        "clinic": {
          "type": "object"
        }
      }
    },
    "subjective": {
      "type": "object",
      "required": [
        "chief_complaint"
      ],
      "properties": {
        "chief_complaint": {
          "type": "string"
        },
        "hpi": {
          "type": "string"
        },
        "pain_scale": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 10
        },
        "pain_quality": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "medical_history_updates": {
          "description": "Plain narrative OR list of update bullets.",
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        }
      }
    },
    "objective": {
      "type": "object",
      "required": [
        "exam_findings"
      ],
      "properties": {
        "vitals": {
          "type": "object"
        },
        "extra_oral": {
          "type": "string"
        },
        "intra_oral": {
          "type": "string"
        },
        "exam_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "tooth",
              "finding"
            ],
            "properties": {
              "tooth": {
                "type": "string",
                "description": "Universal numbering 1-32 or quadrant"
              },
              "surfaces": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "M",
                    "O",
                    "D",
                    "B",
                    "L",
                    "F",
                    "I"
                  ]
                }
              },
              "finding": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "mild",
                  "moderate",
                  "severe",
                  "none"
                ]
              },
              "source_span": {
                "type": "string",
                "description": "Verbatim transcript quote"
              }
            }
          }
        },
        "radiographs_taken": {
          "description": "Either short-form strings ('PA #19') or structured findings.",
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "type":        { "type": ["string", "null"] },
                  "tooth":       { "type": ["string", "null"] },
                  "findings":    { "type": ["string", "null"] },
                  "source_span": { "type": ["string", "null"] }
                }
              }
            ]
          }
        },
        "perio_summary": {
          "type": "string"
        }
      }
    },
    "assessment": {
      "type": "object",
      "required": [
        "diagnoses"
      ],
      "properties": {
        "diagnoses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "tooth",
              "diagnosis"
            ],
            "properties": {
              "tooth": {
                "type": "string"
              },
              "diagnosis": {
                "type": "string"
              },
              "icd10": {
                "type": "string"
              },
              "differential": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "source_span": {
                "type": "string"
              }
            }
          }
        },
        "prognosis": {
          "type": "string"
        }
      }
    },
    "plan": {
      "type": "object",
      "required": [
        "procedures_today",
        "follow_up"
      ],
      "properties": {
        "procedures_today": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "procedure"
            ],
            "properties": {
              "procedure": {
                "type": "string"
              },
              "tooth": {
                "type": ["string", "null"]
              },
              "surfaces": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "materials": {
                "type": "string"
              },
              "anesthesia": {
                "type": "string"
              },
              "source_span": {
                "type": "string"
              }
            }
          }
        },
        "recommended_future": {
          "description": "Either short-form recommendations or structured items.",
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "object" }
            ]
          }
        },
        "prescriptions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "drug",
              "sig"
            ],
            "properties": {
              "drug": {
                "type": "string"
              },
              "strength": {
                "type": "string"
              },
              "sig": {
                "type": "string"
              },
              "quantity": {
                "description": "Tablet/cap count — integer or string ('20', '20 tablets').",
                "type": ["string", "integer"]
              },
              "refills": {
                "type": "integer"
              },
              "interaction_checked": {
                "type": "boolean"
              }
            }
          }
        },
        "patient_instructions": {
          "type": "string"
        },
        "follow_up": {
          "type": "string"
        }
      }
    },
    "billing": {
      "type": "object",
      "required": [
        "cdt_codes"
      ],
      "properties": {
        "cdt_codes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code"],
            "properties": {
              "code": {
                "description": "Allow null when the Coder agent explicitly declines to bill (no allow-listed code fits).",
                "oneOf": [
                  { "type": "string", "pattern": "^D[0-9]{4}$" },
                  { "type": "null" }
                ]
              },
              "description": { "type": ["string", "null"] },
              "tooth":       { "type": ["string", "null"] },
              "surfaces": {
                "type": ["array", "null"],
                "items": { "type": "string" }
              },
              "rationale":   { "type": ["string", "null"] },
              "source_span": { "type": ["string", "null"] }
            }
          }
        },
        "estimated_total": {
          "type": "number"
        }
      }
    },
    "compliance": {
      "type": "object",
      "required": [
        "tsbde_checklist"
      ],
      "properties": {
        "tsbde_checklist": {
          "type": "object",
          "description": "22 TAC \u00a7108.8 Records of the Dental Patient",
          "properties": {
            "patient_identification_complete": {
              "type": "boolean"
            },
            "medical_history_reviewed": {
              "type": "boolean"
            },
            "informed_consent_documented": {
              "type": "boolean"
            },
            "diagnosis_documented": {
              "type": "boolean"
            },
            "treatment_plan_documented": {
              "type": "boolean"
            },
            "radiographs_justified": {
              "type": "boolean"
            },
            "anesthetic_documented": {
              "type": "boolean"
            },
            "provider_signature_block_present": {
              "type": "boolean"
            }
          }
        },
        "provider_attestation": {
          "type": "object",
          "properties": {
            "signed": {
              "type": "boolean"
            },
            "signed_at": {
              "type": "string"
            },
            "signed_by": {
              "type": "string"
            }
          }
        }
      }
    },
    "grounding": {
      "type": "object",
      "required": [
        "transcript_excerpts"
      ],
      "properties": {
        "transcript_excerpts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "span_id",
              "text",
              "speaker"
            ],
            "properties": {
              "span_id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "speaker": {
                "type": "string",
                "enum": [
                  "provider",
                  "patient",
                  "assistant",
                  "unknown"
                ]
              },
              "t_start": {
                "type": "number"
              },
              "t_end": {
                "type": "number"
              }
            }
          }
        },
        "ungrounded_claims": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}