# DentaScribe — environment variables
# Copy this file to .env and fill in the values you have.
# The app runs in DEMO mode if no keys are provided.

# --- LLM (Note generation / Diarization / NER) ---
# Primary: Anthropic Claude. Optional fallback: OpenAI GPT.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Speech to Text ---
# Default uses OpenAI Whisper API. To switch to Deepgram Nova-3 Medical,
# set STT_PROVIDER=deepgram and provide a DEEPGRAM_API_KEY.
STT_PROVIDER=openai
WHISPER_MODEL=whisper-1
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3-medical

# --- App ---
DENTASCRIBE_DEMO_MODE=auto   # auto | true | false
DENTASCRIBE_DB_PATH=dentascribe.db
