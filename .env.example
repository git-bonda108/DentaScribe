# DentaScribe environment variables
# Copy to .env and fill in. Never commit .env.

# Anthropic / Claude
ANTHROPIC_API_KEY=

# Deepgram (for live STT). Optional — only needed for Live mode with mic input.
DEEPGRAM_API_KEY=

# Defaults
DENTASCRIBE_MODEL=claude-sonnet-4-5
DENTASCRIBE_DB_PATH=./dentascribe.db
DENTASCRIBE_LOG_LEVEL=INFO

# Texas clinic identity (used in SOAP exports)
CLINIC_NAME=Dallas Dental Demo Clinic
CLINIC_ADDRESS=1234 Main St, Dallas, TX 75201
PROVIDER_NAME=Dr. Jane Smith, DDS
PROVIDER_TSBDE_LICENSE=
